+/// Communicates with the OpenClaw gateway exclusively over WebSocket.
+///
+/// Protocol summary:
+/// 1. Connect WS to ws(s)://host:port
+/// 2. Gateway sends {type:"event", event:"connect.challenge"}
+/// 3. Client sends {type:"req", method:"connect", params:{auth,client,...}}
+/// 4. Gateway replies {type:"res", ok:true, ...} → authenticated
+/// 5. Subscribe to session messages: {type:"req", method:"sessions.messages.subscribe", params:{key:sessionKey}}
+/// 6. Send a chat message: {type:"req", method:"chat.send", params:{sessionKey, message, idempotencyKey}}
+/// → immediate {type:"res", ok:true, payload:{runId, status:"started"}}
+/// → streamed {type:"event", event:"session.message", payload:{sessionKey, message:{role,content,...}}}
+/// → final message has status:"final" or role=="assistant"
+/// 7. POST /tools/invoke still uses HTTP (unchanged).
