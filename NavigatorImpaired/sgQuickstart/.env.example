# Copy to .env and fill in. Do not commit .env.
# iOS app posts fall alerts to this server (Settings → Fall alert email relay URL).

# Required for any send
SENDGRID_API_KEY=

# Must be a verified Sender Identity in SendGrid
SENDGRID_FROM_EMAIL=you@verified-domain.com
SENDGRID_FROM_NAME=SightAssist

# Relay server
PORT=8787

# Optional: if set, the iOS app must send the same value in header X-Relay-Secret
RELAY_SECRET=

# npm run demo — where to send the tutorial email
DEMO_TO=your-inbox@example.com
