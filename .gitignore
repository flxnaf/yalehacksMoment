Pods/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# CoreML model — too large for git, download with setup_model.sh
**/*.mlpackage
**/*.mlmodelc

# Hugging Face CLI cache — must not live under the app’s synchronized folder or Xcode
# compiles the same .mlpackage twice (“Multiple commands produce”).
DepthanythingTest/DepthanythingTest/.cache/

# Local Hugging Face cache for setup_model.sh
.hf-home/

# Meta SDK — resolved automatically by Xcode SPM
meta-wearables-dat-ios/

# VisionClaw — real API keys (never commit). Template: VisionClaw/Secrets.swift.example
DepthanythingTest/DepthanythingTest/VisionClaw/Secrets.swift
